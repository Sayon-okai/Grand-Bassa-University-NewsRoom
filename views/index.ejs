<%- include("partials/header.ejs") %>
<h1 id="user-name"></h1>
<main onclick="hideSideBar()">
           

    <img src="/images/news_images/entrance_exam.jpg" alt="web 3 hero image" class="hero-pic slide-right">


    
     <section class="side-article">
   
        
    <% if (locals.result) { %>
        <div class="weather"
            style="background: url(../images/weather.jpeg); background-repeat: no-repeat; background-size: cover;">

            <div class="weather-data">
                <div class="city">  City: 
                    <span>
                        <%= result.location.name %>
                    </span> 
                </div>

                <div class="country"> Country: 
                    <span>
                        <%= result.location.country %>
                    </span> 
                </div>

                <div class="obs_time">  Observation Time:
                    <span>
                        <%= result.current.observation_time %>
                    </span>
                 </div>

                <div class="temperature"> Temperature: 
                    <span>
                        <%= result.current.temperature %> <sup><%= result.request.unit %></sup>
                    </span> 
                </div>
                <div class="weather_desc">  Weather Descriptions: 
                    <span>
                        <%= result.current.weather_descriptions %>
                    </span> 
                    <br> <img src="<%= result.current.weather_icons[0]%>" alt="Weather Icon" srcset=""> 
                </div>
            </div>
            </div>
           
            <div class="time-block">
                <div class="time-info"> Sunrise: <span class="sunrise">
                        <%= result.current.astro.sunrise %>
                    </span> <br> Sunset: <span class="sunset">
                        <%= result.current.astro.sunset %>
                    </span> </div>
            </div>
        </div>
        <% } %>
            <% if (locals.error) { %>
                <h2 style="color: red;">
                    <%= error %>
                </h2>
                <% } %>

  <form action="/getweather" method="POST">
    <input type="text" name="country" id="search-box" placeholder="Search Country for Weather Info">
    <input type="submit" value="Search" class="search-btn">
  </form>
        <!-- 
        TODO: Content here will be load dynamically, from json data 
        -->
